APP_NAME=CelebA Face Similarity API
APP_VERSION=0.1.0
APP_ENVIRONMENT=development
FACE_API_KEY="change-me-local-dev-key"
FACE_MODEL_ID="celeba-face-similarity-cpu"
MODEL_ASSET_DIR="models"
